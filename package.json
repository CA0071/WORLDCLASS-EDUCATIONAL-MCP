{
  "name": "schoolme101-mcp",
  "version": "1.0.0",
  "description": "Production-ready MCP server foundation for Africa and South Africa education on Cloudflare Workers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev src/index.ts --env development --local",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "node --import tsx --test src/tests/**/*.test.ts",
    "deploy": "wrangler deploy --env production"
  },
  "keywords": [
    "mcp",
    "cloudflare-workers",
    "education",
    "south-africa",
    "android"
  ],
  "author": "SCHOOLME101",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/node": "^22.15.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
