{
  "name": "school101-mcp",
  "version": "1.0.0",
  "description": "Global MCP for Education - Unified Model Context Protocol Server for K-12, Higher Education, and EdTech Platforms",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "deploy:cloudflare": "wrangler deploy",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "education",
    "k12",
    "learning",
    "canvas",
    "lms",
    "standards",
    "ai",
    "llm"
  ],
  "author": "SCHOOL101 Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-sdk/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pg": "^8.11.2",
    "redis": "^4.6.11",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "wrangler": "^3.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
