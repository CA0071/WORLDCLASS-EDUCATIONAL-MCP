# Core environment
ENVIRONMENT=development
LOG_LEVEL=debug

# Auth hook points (replace with real identity provider values)
AUTH_ISSUER=https://auth.example.com/
AUTH_AUDIENCE=schoolme101-mcp
AUTH_BYPASS_TOKEN=dev-admin-token

# Phase 2: HS256 JWT secret — set in production via: wrangler secret put JWT_SECRET
# Tokens must carry a `role` claim (student|teacher|lecturer|admin) and optional `sub`.
# JWT_SECRET=<your-strong-random-secret>

# Destructive action approval flow hook
APPROVAL_BYPASS_CODE=dev-approval-code

# Rate limiting strategy settings (Cloudflare edge gate)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Cloudflare resource placeholders
CACHE_KV_NAMESPACE_ID=
AUDIT_KV_NAMESPACE_ID=
D1_DATABASE_ID=
R2_BUCKET_NAME=

# Android integration token handling notes
ANDROID_TOKEN_HEADER=Authorization
ANDROID_SYNC_RETRY_LIMIT=5
