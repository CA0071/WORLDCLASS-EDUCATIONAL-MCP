# SCHOOL101 - Global MCP for Education
# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (for local development)
PORT=3000

# Environment: development | staging | production
ENVIRONMENT=development

# Log level: error | warn | info | debug
LOG_LEVEL=debug

# MCP Transport: stdio | http | sse
# stdio: Standard input/output (best for local development)
# http: HTTP polling
# sse: Server-Sent Events (best for cloud deployment)
MCP_TRANSPORT=stdio

# API Base URL (for Cloudflare deployment)
API_BASE_URL=https://api.school101.localhost

# ============================================================================
# CANVAS LMS INTEGRATION
# ============================================================================

# Canvas API Token (from Canvas Settings > Approved Integrations)
# Get this from: https://yourschool.instructure.com/profile/settings
CANVAS_API_TOKEN=your_canvas_api_token_here

# Canvas Instance URL (e.g., https://yourschool.instructure.com)
CANVAS_INSTANCE_URL=https://yourschool.instructure.com

# Enable Canvas integration
CANVAS_ENABLED=true

# ============================================================================
# GOOGLE CLASSROOM INTEGRATION (Phase 2)
# ============================================================================

# Google Cloud Project ID
GOOGLE_PROJECT_ID=your-project-id

# Google OAuth 2.0 Credentials (Service Account JSON path or inline)
GOOGLE_CREDENTIALS_PATH=./credentials/google-credentials.json

# Enable Google Classroom integration
GOOGLE_CLASSROOM_ENABLED=false

# ============================================================================
# MICROSOFT INTEGRATIONS
# ============================================================================

# Microsoft Azure AD Configuration
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret

# Microsoft Learn API Key
MICROSOFT_LEARN_API_KEY=your-microsoft-learn-api-key

# Enable Microsoft integrations
MICROSOFT_TEAMS_ENABLED=false
MICROSOFT_LEARN_ENABLED=true

# ============================================================================
# RESEARCH & ACADEMIC TOOLS
# ============================================================================

# Semantic Scholar API Key
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key

# Wolfram Alpha API Key
WOLFRAM_API_KEY=your-wolfram-api-key

# Zotero API Key (for research reference management)
ZOTERO_API_KEY=your-zotero-api-key

# Enable research tools
WOLFRAM_ENABLED=true
ZOTERO_ENABLED=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://school101:password@localhost:5432/school101_dev

# Redis Connection String (for caching and sessions)
# Format: redis://:password@host:port/db
REDIS_URL=redis://localhost:6379/0

# Database SSL (for production)
DATABASE_SSL=false
DATABASE_SSL_CERT_PATH=./certs/db-cert.pem

# ============================================================================
# FILE STORAGE (Cloudflare R2 or AWS S3)
# ============================================================================

# Storage provider: r2 | s3 | local
STORAGE_PROVIDER=local

# For Cloudflare R2:
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_ACCESS_KEY_SECRET=your-access-key-secret
R2_BUCKET_NAME=school101-data

# For AWS S3:
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=school101-data

# For local storage (development only)
LOCAL_STORAGE_PATH=./data/uploads

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret for token signing
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# JWT Expiration (in hours)
JWT_EXPIRATION_HOURS=24

# API Key for direct API access (development only)
API_KEY_DEV=dev-api-key-12345

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://school101.ai

# Enable HTTPS only
HTTPS_ONLY=false

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=100

# Session timeout (in minutes)
SESSION_TIMEOUT_MINUTES=60

# ============================================================================
# K-12 STANDARDS DATABASE
# ============================================================================

# Standards database provider: local | external
STANDARDS_PROVIDER=local

# Path to local K-12 standards database
STANDARDS_DB_PATH=./data/standards/k12-standards.json

# Enable specific standards frameworks
ENABLE_COMMON_CORE=true
ENABLE_NGSS=true
ENABLE_STATE_STANDARDS=true

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================

# Email provider: sendgrid | mailgun | smtp | none
EMAIL_PROVIDER=none

# SendGrid API Key
SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun API Configuration
MAILGUN_DOMAIN=mg.school101.ai
MAILGUN_API_KEY=your-mailgun-api-key

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@school101.ai
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@school101.ai

# Enable email notifications
EMAIL_ENABLED=false

# Slack notifications (for admin alerts)
SLACK_WEBHOOK_URL=

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Analytics provider: mixpanel | amplitude | google-analytics | none
ANALYTICS_PROVIDER=none

# Mixpanel Token
MIXPANEL_TOKEN=your-mixpanel-token

# Google Analytics Tracking ID
GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry (error tracking)
SENTRY_DSN=

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable experimental features
FEATURE_PREDICTIVE_ANALYTICS=false
FEATURE_AI_FEEDBACK=false
FEATURE_PERSONALIZED_PATHWAYS=false
FEATURE_PARENT_PORTAL=false

# Beta features
BETA_FEATURES_ENABLED=false

# ============================================================================
# SPECIAL EDUCATION & ACCESSIBILITY
# ============================================================================

# Enable accessibility features
ACCESSIBILITY_ENABLED=true

# WCAG Compliance Level: A | AA | AAA
WCAG_LEVEL=AA

# Enable text-to-speech
TEXT_TO_SPEECH_ENABLED=true

# TTS Provider: google | azure | aws
TTS_PROVIDER=google

# Enable alt-text generation for images
AUTO_ALT_TEXT_ENABLED=true

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================

# Enable FERPA privacy mode (for Canvas)
FERPA_MODE_ENABLED=true

# Enable COPPA compliance (for elementary schools)
COPPA_MODE_ENABLED=false

# Data retention policy (in days, 0 = no deletion)
DATA_RETENTION_DAYS=1825  # 5 years

# Enable audit logging
AUDIT_LOGGING_ENABLED=true

# Encryption at rest
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY_PATH=./certs/encryption-key.pem

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable debug mode (verbose logging)
DEBUG=false

# Mock external APIs (for testing without real credentials)
MOCK_EXTERNAL_APIS=false

# Enable API documentation (Swagger UI)
API_DOCS_ENABLED=true
API_DOCS_PATH=/api/docs

# Enable request/response logging
LOG_REQUESTS=false

# ============================================================================
# CLOUDFLARE SPECIFIC
# ============================================================================

# Cloudflare Account ID (for Workers deployment)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare API Token
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# KV Namespace IDs
KV_CACHE_NAMESPACE_ID=your-kv-cache-id
KV_AUTH_NAMESPACE_ID=your-kv-auth-id

# D1 Database ID
D1_DATABASE_ID=your-d1-database-id

# Enable Cloudflare Analytics Engine
ANALYTICS_ENGINE_ENABLED=false

# ============================================================================
# THIRD-PARTY INTEGRATIONS (FUTURE PHASES)
# ============================================================================

# Gradescope Integration
GRADESCOPE_API_KEY=

# Blackboard Integration
BLACKBOARD_KEY=
BLACKBOARD_SECRET=

# Moodle Integration
MOODLE_URL=
MOODLE_TOKEN=

# Turnitin Integration
TURNITIN_API_KEY=

# OpenAI/Claude API (for advanced AI features)
ANTHROPIC_API_KEY=

# ============================================================================
# NOTES
# ============================================================================

# This file contains sensitive information. Never commit it to version control.
# Use: git update-index --assume-unchanged .env

# For local development:
# 1. Copy this file to .env
# 2. Fill in your actual API keys and credentials
# 3. Run: npm run dev

# For production deployment on Cloudflare:
# Use: wrangler secret put VARIABLE_NAME
# Example: wrangler secret put CANVAS_API_TOKEN
